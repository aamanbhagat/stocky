generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Company {
  id              Int      @id @default(autoincrement())
  slug            String   @unique
  symbol          String
  name            String
  cin             String?
  isin            String?  @unique
  exchange        String
  sector          String?
  industry        String?

  marketCap       Float?   // in ₹ Crore
  currentPrice    Float?
  dayChange       Float?
  dayChangePct    Float?
  high52          Float?
  low52           Float?
  peRatio         Float?
  pbRatio         Float?
  dividendYield   Float?   // percent

  // Per-share + returns
  eps             Float?
  bookValue       Float?
  roe             Float?   // percent
  roa             Float?   // percent
  faceValueRatio  Float?

  // Balance sheet / income (all ₹ Crore)
  revenue         Float?
  ebitda          Float?
  netProfit       Float?
  totalDebt       Float?
  totalCash       Float?
  debtToEquity    Float?   // ratio (x)
  currentRatio    Float?

  // Growth + margins (percent)
  revenueGrowth   Float?
  earningsGrowth  Float?
  profitMargin    Float?
  operatingMargin Float?

  // Dividend / risk
  dividendRate    Float?
  payoutRatio     Float?   // percent
  beta            Float?

  // Analyst
  targetPrice     Float?
  recommendation  String?
  analystCount    Int?

  sharesOutstanding Float?
  employees       Int?

  promoterHolding   Float?
  institutionalHolding Float?  // FII + DII combined
  fiHolding         Float?
  diHolding         Float?
  publicHolding     Float?     // retail / non-institutional public
  shareholdingDate  DateTime?  // "as of" quarter-end of the pattern
  shareholdingSrc   String?    // NSE | Yahoo

  description     String?
  longSummary     String?  // sourced business summary, preferred over generated
  foundedYear     Int?
  headquarters    String?
  website         String?
  listingDate     DateTime?

  faceValue       Float?
  series          String?
  bseCode         String?
  yahooSymbol     String?
  pricedAt        DateTime?

  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())

  @@index([sector])
  @@index([exchange])
  @@index([symbol])
  @@index([marketCap])
}

model UpdateLog {
  id        Int      @id @default(autoincrement())
  job       String
  ok        Int
  failed    Int
  notes     String?
  runAt     DateTime @default(now())
}
